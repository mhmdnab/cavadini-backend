{
  "name": "cavadini-backend",
  "version": "1.0.0",
  "description": "REST API backend for Cavadini luxury watch e-commerce",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "prisma generate && prisma migrate deploy && tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "ts-node src/seed/index.ts",
    "seed:admin": "ts-node src/seedAdmin.ts",
    "seed:kampfer": "ts-node scripts/seedKampferProducts.ts",
    "scrape:images": "node scripts/scrapeEbayImages.js",
    "seed:gender": "ts-node scripts/seedGender.ts",
    "migrate:watch-categories": "ts-node scripts/migrateWatchCategories.ts",
    "seed:images": "ts-node scripts/seedProductImages.ts",
    "seed:images:supabase": "ts-node scripts/seedProductImages.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.103.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "nodemon": "^3.1.3",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
