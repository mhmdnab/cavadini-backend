generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
  carts  Cart[]

  @@map("users")
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  themes   Theme[]
  products Product[]

  @@map("categories")
}

// ─── Brand ────────────────────────────────────────────────────────────────────

model Brand {
  id         String    @id @default(uuid())
  name       String    @unique
  slug       String    @unique
  categories String[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@map("brands")
}

// ─── Theme ────────────────────────────────────────────────────────────────────

model Theme {
  id         String   @id @default(uuid())
  name       String
  slug       String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  productThemes ProductTheme[]

  @@index([categoryId])
  @@index([slug])
  @@map("themes")
}

// ─── Product (single-table, mirrors Mongoose discriminator pattern) ────────────

model Product {
  id            String  @id @default(uuid())
  categoryId    String
  brandId       String?
  category_type String

  referenceNumber String?
  name            String
  description     String?
  price           Float
  originalPrice   Float?
  currency        String  @default("EUR")
  isOnSale        Boolean @default(false)
  stockQuantity   Int     @default(0)
  isActive        Boolean @default(true)
  isSecondHand    Boolean @default(false)

  // Compliance
  warningNotForChildrenUnder3 Boolean @default(false)
  warningContainsButtonCell   Boolean @default(false)
  weeeRegNumber               String?
  manufacturerInfo            String?
  responsiblePersonEU         String?
  safetyInfo                  String?
  packageContents             String?

  // Watch-specific
  gender                  String?
  movement                String?
  caseMaterial            String?
  strapMaterial           String?
  caseColor               String?
  strapColor              String?
  dialColor               String?
  displayType             String?
  waterResistance         String?
  watchShape              String?
  caseFinish              String?
  crystalType             String?
  bezel                   String?
  caseBack                String?
  dialPattern             String?
  settingAdornment        String?
  clasp                   String?
  functions               String[]
  styles                  String[]
  caliber                 String?
  yearOfManufacture       Int?
  diameterMm              Float?
  caseThicknessMm         Float?
  lugWidthMm              Float?
  maxWristCircumferenceMm Float?

  // Strap-specific (material, color, clasp, lugWidthMm shared above)
  fitting      String?
  claspWidthMm Float?
  minLengthMm  Float?
  maxLengthMm  Float?

  // Box-specific
  capacity   String?
  dimensions String?

  // Bundle-specific
  bundleType      String?
  contentsSummary String?

  // Workshop-specific
  weeeRegNumberBatteries String?

  // Jewelry-specific (gender, style shared above)
  productType           String?
  shortDescription      String?
  itemName              String?
  weightGrams           Float?
  style                 String?
  material              String?
  color                 String?
  ringSizeCircumference String?
  chainLengthMm         Float?
  chainWidthMm          Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  brand         Brand?         @relation(fields: [brandId], references: [id])
  productThemes ProductTheme[]
  orderItems    OrderItem[]
  cartItems     CartItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([isOnSale])
  @@index([isActive])
  @@index([isSecondHand])
  @@index([price])
  @@index([category_type])
  @@index([category_type, movement])
  @@index([category_type, caseMaterial])
  @@index([category_type, gender])
  @@index([category_type, waterResistance])
  @@index([category_type, dialColor])
  @@index([category_type, caseColor])
  @@index([category_type, strapColor])
  @@index([category_type, displayType])
  @@index([category_type, clasp])
  @@index([category_type, fitting])
  @@index([category_type, lugWidthMm])
  @@map("products")
}

// ─── ProductTheme (M:M junction) ─────────────────────────────────────────────

model ProductTheme {
  productId String
  themeId   String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  theme   Theme   @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([productId, themeId])
  @@map("product_themes")
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  userId          String
  totalAmount     Float
  status          OrderStatus @default(pending)
  shippingAddress Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@map("orders")
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id])
  items CartItem[]

  @@index([userId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String
  quantity  Int

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@map("cart_items")
}

// ─── Newsletter ───────────────────────────────────────────────────────────────

model Newsletter {
  id           String   @id @default(uuid())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@map("newsletter")
}
